{
  "description": "Forward all Claude Code lifecycle events to the Weave daemon",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-handler.sh", "timeout": 10}]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-handler.sh", "timeout": 10}]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-handler.sh", "timeout": 10}]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-handler.sh", "timeout": 10}]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-handler.sh", "timeout": 10}]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-handler.sh", "timeout": 10}]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-handler.sh", "timeout": 10}]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-handler.sh", "timeout": 10}]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-handler.sh", "timeout": 10}]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-handler.sh", "timeout": 10}]
      }
    ],
    "PermissionDenied": [
      {
        "matcher": "*",
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-handler.sh", "timeout": 10}]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-handler.sh", "timeout": 10}]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-handler.sh", "timeout": 10}]
      }
    ],
    "InstructionsLoaded": [
      {
        "matcher": "*",
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-handler.sh", "timeout": 10}]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "*",
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-handler.sh", "timeout": 10}]
      }
    ],
    "WorktreeCreate": [
      {
        "matcher": "*",
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-handler.sh", "timeout": 10}]
      }
    ],
    "WorktreeRemove": [
      {
        "matcher": "*",
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-handler.sh", "timeout": 10}]
      }
    ],
    "TeammateIdle": [
      {
        "matcher": "*",
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-handler.sh", "timeout": 10}]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "*",
        "hooks": [{"type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/hook-handler.sh", "timeout": 10}]
      }
    ]
  }
}
