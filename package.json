{
  "name": "weave-claude-code",
  "version": "0.2.6",
  "description": "Track Claude Code sessions in Weave for observability and debugging",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "weave-claude-code": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && node scripts/build/copy-version-module.mjs",
    "build:watch": "tsc --watch",
    "dev": "tsx src/cli.ts",
    "test": "node --import tsx --test tests/*.test.ts",
    "secrets:scan": "gitleaks dir . --no-banner --redact",
    "secrets:scan:staged": "gitleaks git --pre-commit --staged --redact --verbose",
    "check": "npm run build && npm test && npm run secrets:scan",
    "setup-hooks": "node scripts/install-git-hooks.mjs"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "uuidv7": "1.2.1",
    "weave": "file:../weave/sdks/node"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=24.14.0"
  },
  "files": [
    "dist/",
    "hooks/",
    "skills/",
    ".claude-plugin/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wandb/weave-claude-code.git"
  },
  "license": "MIT"
}
